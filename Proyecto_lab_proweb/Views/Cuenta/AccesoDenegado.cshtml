@{
    ViewData["Title"] = "Acceso Denegado";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
         <div class="card">
            <div class="card-body text-center">
  <h1 class="text-danger">
       <i class="bi bi-shield-exclamation"></i>
   </h1>
        <h2 class="text-danger">Acceso Denegado</h2>
            <hr />
        <p class="lead">
              No tiene permisos para acceder a esta pagina.
        </p>
    <p>
     Si cree que esto es un error, por favor contacte al administrador del sistema.
</p>
     <div class="mt-4">
      <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Volver al Inicio</a>
 @if (!User.Identity?.IsAuthenticated ?? true)
        {
                <a asp-controller="Cuenta" asp-action="Login" class="btn btn-secondary">Iniciar Sesion</a>
             }
         </div>
                </div>
          </div>
        </div>
    </div>
</div>
