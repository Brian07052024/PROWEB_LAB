@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
           <div class="card-body text-center">
         <h1 class="text-danger">Error</h1>
<h2 class="text-danger">Ocurrio un error al procesar su solicitud.</h2>
     
          @if (Model?.ShowRequestId ?? false)
           {
                  <p>
    <strong>ID de Solicitud:</strong> <code>@Model?.RequestId</code>
        </p>
           }

         <hr />
       <p>
        Por favor, intente nuevamente mas tarde o contacte al administrador del sistema si el problema persiste.
       </p>
     <div class="mt-4">
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Volver al Inicio</a>
   </div>
        </div>
         </div>
        </div>
    </div>
</div>
