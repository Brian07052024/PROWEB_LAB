<!DOCTYPE html>
<html lang="es" class="h-100">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>@ViewData["Title"] - Sistema de Inventario</title>
	<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
	<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
	<link rel="stylesheet" href="~/Proyecto_lab_proweb.styles.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column h-100">
	<header>
		<nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
			<div class="container">
				<a class="navbar-brand d-flex align-items-center" asp-controller="Home" asp-action="Index">
					<i class="bi bi-box-seam me-2"></i>
					<span>Sistema de Inventario</span>
				</a>
				<button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
					<span class="navbar-toggler-icon"></span>
				</button>
				<div class="collapse navbar-collapse" id="navbarMain">
					<ul class="navbar-nav me-auto mb-2 mb-lg-0">
						<li class="nav-item">
							<a class="nav-link" asp-controller="Home" asp-action="Index">
								<i class="bi bi-house-door me-1"></i>Inicio
							</a>
						</li>
						<li class="nav-item">
							<a class="nav-link" asp-controller="Home" asp-action="Catalogo">
								<i class="bi bi-grid me-1"></i>Catalogo
							</a>
						</li>
						<li class="nav-item">
							<a class="nav-link" asp-controller="Home" asp-action="Acerca">
								<i class="bi bi-info-circle me-1"></i>Acerca
							</a>
						</li>
						<li class="nav-item">
							<a class="nav-link" asp-controller="Home" asp-action="Contacto">
								<i class="bi bi-envelope me-1"></i>Contacto
							</a>
						</li>
					</ul>

					@if (User.IsInRole("Admin"))
					{
						<ul class="navbar-nav me-auto">
							<li class="nav-item dropdown">
								<a class="nav-link dropdown-toggle" href="#" id="adminDropdown" role="button" data-bs-toggle="dropdown">
									<i class="bi bi-shield-lock me-1"></i>Administracion
								</a>
								<ul class="dropdown-menu dropdown-menu-dark">
									<li>
										<a class="dropdown-item" asp-controller="Dashboard" asp-action="Index">
											<i class="bi bi-speedometer2 me-2"></i>Dashboard
										</a>
									</li>
									<li><hr class="dropdown-divider" /></li>
									<li>
										<a class="dropdown-item" asp-controller="Productos" asp-action="Index">
											<i class="bi bi-box me-2"></i>Productos
										</a>
									</li>
									<li>
										<a class="dropdown-item" asp-controller="Categorias" asp-action="Index">
											<i class="bi bi-tags me-2"></i>Categorias
										</a>
									</li>
									<li>
										<a class="dropdown-item" asp-controller="Proveedores" asp-action="Index">
											<i class="bi bi-truck me-2"></i>Proveedores
										</a>
									</li>
								</ul>
							</li>
						</ul>
					}

					<ul class="navbar-nav">
						@if (User.Identity?.IsAuthenticated == true)
						{
							<li class="nav-item dropdown">
								<a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown">
									<i class="bi bi-person-circle me-1"></i>@User.Identity.Name
								</a>
								<ul class="dropdown-menu dropdown-menu-end dropdown-menu-dark">
									<li>
										<span class="dropdown-item-text text-muted">
											<small>@(User.IsInRole("Admin") ? "Administrador" : "Usuario")</small>
										</span>
									</li>
									<li><hr class="dropdown-divider" /></li>
									<li>
										<form asp-controller="Cuenta" asp-action="Logout" method="post">
											<button type="submit" class="dropdown-item">
												<i class="bi bi-box-arrow-right me-2"></i>Cerrar Sesion
											</button>
										</form>
									</li>
								</ul>
							</li>
						}
						else
						{
							<li class="nav-item">
								<a class="nav-link text-white" asp-controller="Cuenta" asp-action="Login">
									<i class="bi bi-box-arrow-in-right me-1 text-white"></i>Iniciar Sesion
								</a>
							</li>
							<li class="nav-item">
								<a class="nav-link text-white" asp-controller="Cuenta" asp-action="Registro">
									<i class="bi bi-person-plus me-1 text-white"></i>Registrarse
								</a>
							</li>
						}
					</ul>
				</div>
			</div>
		</nav>
	</header>

	<div class="container-fluid py-3 flex-grow-1">
		@if (TempData["Exito"] != null)
		{
			<div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
				<i class="bi bi-check-circle me-2"></i>@TempData["Exito"]
				<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
			</div>
		}
		@if (TempData["Error"] != null)
		{
			<div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
				<i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
				<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
			</div>
		}
		@if (TempData["Advertencia"] != null)
		{
			<div class="alert alert-warning alert-dismissible fade show shadow-sm" role="alert">
				<i class="bi bi-exclamation-circle me-2"></i>@TempData["Advertencia"]
				<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
			</div>
		}

		<main role="main" class="pb-3">
			@RenderBody()
		</main>
	</div>

	<footer class="bg-dark text-light py-4 mt-auto">
		<div class="container">
			<div class="row">
				<div class="col-md-6">
					<h6><i class="bi bi-box-seam me-2"></i>Sistema de Inventario</h6>
					<p class="text-muted small mb-0">
						Gestion eficiente de productos, categorias y proveedores.
					</p>
				</div>
				<div class="col-md-6 text-md-end">
					<p class="mb-0 small text-muted">
						&copy; 2026 - Todos los derechos reservados
					</p>
					<p class="mb-0">
						<a asp-controller="Home" asp-action="Privacy" class="text-muted text-decoration-none small">
							<i class="bi bi-shield-check me-1"></i>Privacidad
						</a>
					</p>
				</div>
			</div>
		</div>
	</footer>

	<script src="~/lib/jquery/dist/jquery.min.js"></script>
	<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
	<script src="~/js/site.js" asp-append-version="true"></script>
	@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
