@{
	ViewData["Title"] = "Acerca de Nosotros";
}

<div class="container">
	<h1>@ViewData["Title"]</h1>
	<hr />
	<div class="row">
		<div class="col-md-8">
			<h3>Sistema de Gestión de Inventario</h3>
			<p class="lead">
				Una solución completa para la gestión eficiente de inventarios empresariales.
			</p>
			<p>
				Nuestro sistema permite a las organizaciones mantener un control preciso de sus productos,
				categorías y proveedores, facilitando la toma de decisiones y optimizando los procesos de gestión.
			</p>
			<h4 class="mt-4">Características Principales:</h4>
			<ul>
				<li>Gestión completa de productos con información detallada</li>
				<li>Organización por categorías para fácil navegación</li>
				<li>Control de proveedores y sus contactos</li>
				<li>Sistema de autenticación y roles de usuario</li>
				<li>Interfaz intuitiva y responsive</li>
				<li>Reportes y visualización de inventario en tiempo real</li>
			</ul>
		</div>
		<div class="col-md-4">
			<div class="card">
				<div class="card-body">
					<h5 class="card-title">Información del Proyecto</h5>
					<p class="card-text">
						<strong>Versión:</strong> 1.0.0<br />
						<strong>Tecnología:</strong> ASP.NET Core 9.0<br />
						<strong>Base de Datos:</strong> SQL Server<br />
						<strong>Ańo:</strong> 2026
					</p>
				</div>
			</div>
		</div>
	</div>
</div>
