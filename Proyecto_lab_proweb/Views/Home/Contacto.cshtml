@{
	ViewData["Title"] = "Contacto";
}

<div class="container">
	<h1>@ViewData["Title"]</h1>
	<hr />
	<div class="row">
		<div class="col-md-6">
			<h3>Información de Contacto</h3>
			<p class="lead">¿Tienes preguntas? Estamos aquí para ayudarte.</p>

			<div class="mt-4">
				<h5><i class="bi bi-building"></i> Dirección</h5>
				<p>Avenida Principal #123<br />Ciudad Universitaria<br />País</p>
			</div>

			<div class="mt-3">
				<h5><i class="bi bi-telephone"></i> Teléfono</h5>
				<p>+123 456 7890</p>
			</div>

			<div class="mt-3">
				<h5><i class="bi bi-envelope"></i> Email</h5>
				<p>contacto@sistemainventario.com</p>
			</div>

			<div class="mt-3">
				<h5><i class="bi bi-clock"></i> Horario de Atención</h5>
				<p>Lunes a Viernes: 8:00 AM - 6:00 PM<br />Sábado: 9:00 AM - 2:00 PM</p>
			</div>
		</div>

		<div class="col-md-6">
			<h3>Envíanos un Mensaje</h3>
			<form>
				<div class="mb-3">
					<label for="nombre" class="form-label">Nombre Completo</label>
					<input type="text" class="form-control" id="nombre" placeholder="Tu nombre">
				</div>
				<div class="mb-3">
					<label for="email" class="form-label">Correo Electrónico</label>
					<input type="email" class="form-control" id="email" placeholder="tu@email.com">
				</div>
				<div class="mb-3">
					<label for="asunto" class="form-label">Asunto</label>
					<input type="text" class="form-control" id="asunto" placeholder="Asunto del mensaje">
				</div>
				<div class="mb-3">
					<label for="mensaje" class="form-label">Mensaje</label>
					<textarea class="form-control" id="mensaje" rows="5" placeholder="Escribe tu mensaje aquí"></textarea>
				</div>
				<button type="button" class="btn btn-primary" onclick="alert('Funcionalidad de envío pendiente de implementación')">Enviar Mensaje</button>
			</form>
		</div>
	</div>
</div>
