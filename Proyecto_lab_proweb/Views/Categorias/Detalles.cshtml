@model Proyecto_lab_proweb.Models.Categoria

@{
    ViewData["Title"] = "Detalles de CategorÝa";
}

<div class="container">
    <h1>@ViewData["Title"]</h1>
  <hr />
    
    <div class="card">
  <div class="card-body">
      <dl class="row">
  <dt class="col-sm-3">Nombre</dt>
    <dd class="col-sm-9">@Model.Nombre</dd>
    
 <dt class="col-sm-3">Descripciˇn</dt>
  <dd class="col-sm-9">@Model.Descripcion</dd>
        
   <dt class="col-sm-3">Productos</dt>
   <dd class="col-sm-9">
  <span class="badge bg-info">@Model.Productos.Count productos</span>
  </dd>
  </dl>
        </div>
    </div>
    
    @if (Model.Productos.Any())
 {
        <h3 class="mt-4">Productos en esta CategorÝa</h3>
   <table class="table table-sm">
      <thead>
   <tr>
    <th>Nombre</th>
     <th>Precio</th>
      <th>Stock</th>
   </tr>
    </thead>
          <tbody>
  @foreach (var producto in Model.Productos)
   {
     <tr>
   <td>@producto.Nombre</td>
      <td>@producto.Precio.ToString("C")</td>
      <td>@producto.Stock</td>
    </tr>
    }
      </tbody>
        </table>
    }
    
    <div class="mt-3">
<a asp-action="Editar" asp-route-id="@Model.Id" class="btn btn-warning">Editar</a>
<a asp-action="Index" class="btn btn-secondary">Volver a la Lista</a>
    </div>
</div>
