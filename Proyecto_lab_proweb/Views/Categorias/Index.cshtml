@model IEnumerable<Proyecto_lab_proweb.Models.Categoria>

@{
	ViewData["Title"] = "Categorias";
}

<div class="container-fluid">
	<!-- Encabezado -->
	<div class="d-flex justify-content-between align-items-center mb-4">
		<div>
			<h1 class="h3 mb-0">
				<i class="bi bi-tags me-2"></i>Gestion de Categorias
			</h1>
			<p class="text-muted mb-0">Administra las categorias de productos</p>
		</div>
		<a asp-action="Crear" class="btn btn-success">
			<i class="bi bi-plus-lg me-1"></i>Nueva Categoria
		</a>
	</div>

	<!-- Tabla de Categorias -->
	<div class="card border-0 shadow-sm">
		<div class="table-responsive">
			<table class="table table-hover align-middle mb-0">
				<thead class="table-light">
					<tr>
						<th style="width: 25%">Nombre</th>
						<th style="width: 45%">Descripcion</th>
						<th class="text-center" style="width: 15%">Productos</th>
						<th class="text-center" style="width: 15%">Acciones</th>
					</tr>
				</thead>
				<tbody>
					@if (Model.Any())
					{
						@foreach (var categoria in Model)
						{
							<tr>
								<td>
									<div class="d-flex align-items-center">
										<div class="bg-success bg-opacity-10 rounded-circle p-2 me-2">
											<i class="bi bi-tag text-success"></i>
										</div>
										<span class="fw-medium">@categoria.Nombre</span>
									</div>
								</td>
								<td>
									<span class="text-muted">
										@(categoria.Descripcion?.Length > 80 ? categoria.Descripcion.Substring(0, 80) + "..." : categoria.Descripcion)
									</span>
								</td>
								<td class="text-center">
									<span class="badge bg-primary rounded-pill">
										@categoria.Productos.Count producto(s)
									</span>
								</td>
								<td class="text-center">
									<div class="btn-group btn-group-sm">
										<a asp-action="Detalles" asp-route-id="@categoria.Id" class="btn btn-outline-info" title="Ver detalles">
											<i class="bi bi-eye"></i>
										</a>
										<a asp-action="Editar" asp-route-id="@categoria.Id" class="btn btn-outline-warning" title="Editar">
											<i class="bi bi-pencil"></i>
										</a>
										<a asp-action="Eliminar" asp-route-id="@categoria.Id" class="btn btn-outline-danger" title="Eliminar">
											<i class="bi bi-trash"></i>
										</a>
									</div>
								</td>
							</tr>
						}
					}
					else
					{
						<tr>
							<td colspan="4" class="text-center py-5">
								<i class="bi bi-inbox fs-1 text-muted"></i>
								<p class="text-muted mt-2 mb-0">No hay categorias registradas</p>
								<a asp-action="Crear" class="btn btn-success mt-3">
									<i class="bi bi-plus-lg me-1"></i>Crear primera categoria
								</a>
							</td>
						</tr>
					}
				</tbody>
			</table>
		</div>
	</div>
</div>
