@model Proyecto_lab_proweb.Models.Producto

@{
    ViewData["Title"] = "Detalles de Producto";
}

<div class="container">
    <!-- Encabezado -->
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
         <h1 class="h3 mb-0">
   <i class="bi bi-eye me-2"></i>Detalles del Producto
            </h1>
         <p class="text-muted mb-0">Informacion completa del producto</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">
    <i class="bi bi-arrow-left me-1"></i>Volver
        </a>
    </div>

    <div class="row">
   <div class="col-lg-8">
    <div class="card border-0 shadow-sm">
      <div class="card-body p-4">
      <div class="d-flex justify-content-between align-items-start mb-4">
         <div>
       <h2 class="mb-1">@Model.Nombre</h2>
      <span class="badge bg-secondary">@Model.Categoria?.Nombre</span>
        </div>
      <div class="text-end">
       <span class="fs-3 fw-bold text-success">@Model.Precio.ToString("C")</span>
  </div>
    </div>

        <hr />

  <div class="row">
       <div class="col-md-6 mb-3">
   <h6 class="text-muted text-uppercase small mb-2">
 <i class="bi bi-text-paragraph me-1"></i>Descripcion
        </h6>
    <p>@(Model.Descripcion ?? "Sin descripcion")</p>
     </div>
      <div class="col-md-6 mb-3">
      <h6 class="text-muted text-uppercase small mb-2">
     <i class="bi bi-box me-1"></i>Stock Disponible
   </h6>
       @if (Model.Stock == 0)
         {
<span class="badge bg-danger fs-6">Agotado</span>
   }
   else if (Model.Stock <= 10)
    {
     <span class="badge bg-warning text-dark fs-6">@Model.Stock unidades</span>
         <span class="text-warning ms-2"><i class="bi bi-exclamation-triangle"></i> Stock bajo</span>
    }
 else
           {
      <span class="badge bg-success fs-6">@Model.Stock unidades</span>
  }
      </div>
    </div>

   <div class="row">
       <div class="col-md-6 mb-3">
 <h6 class="text-muted text-uppercase small mb-2">
          <i class="bi bi-tags me-1"></i>Categoria
    </h6>
   <span class="badge bg-primary">@Model.Categoria?.Nombre</span>
        </div>
 <div class="col-md-6 mb-3">
    <h6 class="text-muted text-uppercase small mb-2">
       <i class="bi bi-truck me-1"></i>Proveedor
   </h6>
    @if (Model.Proveedor != null)
       {
    <span>@Model.Proveedor.Nombre</span>
 }
     else
 {
  <span class="text-muted">Sin proveedor asignado</span>
   }
    </div>
   </div>
   </div>
   <div class="card-footer bg-light border-0 p-3">
   <div class="d-flex justify-content-end gap-2">
 <a asp-action="Editar" asp-route-id="@Model.Id" class="btn btn-warning">
       <i class="bi bi-pencil me-1"></i>Editar
   </a>
    <a asp-action="Eliminar" asp-route-id="@Model.Id" class="btn btn-outline-danger">
    <i class="bi bi-trash me-1"></i>Eliminar
    </a>
    </div>
        </div>
 </div>
        </div>

   <!-- Resumen lateral -->
    <div class="col-lg-4">
     <div class="card border-0 shadow-sm">
   <div class="card-header bg-light border-0">
   <h6 class="mb-0">
       <i class="bi bi-calculator me-1"></i>Resumen
 </h6>
   </div>
       <div class="card-body">
        <dl class="mb-0">
    <dt class="text-muted small">ID Producto</dt>
    <dd class="fs-5">@Model.Id</dd>

    <dt class="text-muted small">Precio Unitario</dt>
          <dd class="fs-5 text-success">@Model.Precio.ToString("C")</dd>

     <dt class="text-muted small">Valor en Inventario</dt>
    <dd class="fs-5 text-primary">@((Model.Precio * Model.Stock).ToString("C"))</dd>
    </dl>
      </div>
     </div>
   </div>
    </div>
</div>
