@model Proyecto_lab_proweb.Models.Producto

@{
    ViewData["Title"] = "Crear Producto";
}

<div class="container">
    <!-- Encabezado -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
    <h1 class="h3 mb-0">
     <i class="bi bi-plus-circle me-2"></i>Crear Nuevo Producto
      </h1>
        <p class="text-muted mb-0">Complete el formulario para agregar un producto</p>
        </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
  <i class="bi bi-arrow-left me-1"></i>Volver
 </a>
    </div>

    <div class="row">
 <div class="col-lg-8">
   <div class="card border-0 shadow-sm">
   <div class="card-body p-4">
 <form asp-action="Crear">
     <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <div class="row g-3">
      <!-- Nombre -->
     <div class="col-md-6">
      <label asp-for="Nombre" class="form-label">
 <i class="bi bi-tag me-1"></i>Nombre del Producto
      </label>
        <input asp-for="Nombre" class="form-control" placeholder="Ingrese el nombre" />
 <span asp-validation-for="Nombre" class="text-danger small"></span>
          </div>

     <!-- Precio -->
 <div class="col-md-3">
 <label asp-for="Precio" class="form-label">
        <i class="bi bi-currency-dollar me-1"></i>Precio
     </label>
  <div class="input-group">
       <span class="input-group-text">$</span>
           <input asp-for="Precio" class="form-control" type="number" step="0.01" min="0" placeholder="0.00" />
  </div>
    <span asp-validation-for="Precio" class="text-danger small"></span>
 </div>

 <!-- Stock -->
        <div class="col-md-3">
        <label asp-for="Stock" class="form-label">
   <i class="bi bi-box me-1"></i>Stock
</label>
  <input asp-for="Stock" class="form-control" type="number" min="0" placeholder="0" />
        <span asp-validation-for="Stock" class="text-danger small"></span>
           </div>

   <!-- Descripcion -->
      <div class="col-12">
   <label asp-for="Descripcion" class="form-label">
   <i class="bi bi-text-paragraph me-1"></i>Descripcion
     </label>
     <textarea asp-for="Descripcion" class="form-control" rows="3" placeholder="Descripcion del producto (opcional)"></textarea>
    <span asp-validation-for="Descripcion" class="text-danger small"></span>
</div>

      <!-- Categoria -->
     <div class="col-md-6">
       <label asp-for="CategoriaId" class="form-label">
       <i class="bi bi-tags me-1"></i>Categoria
        </label>
     <select asp-for="CategoriaId" class="form-select" asp-items="ViewBag.CategoriaId">
 <option value="">-- Seleccione una categoria --</option>
  </select>
      <span asp-validation-for="CategoriaId" class="text-danger small"></span>
 </div>

         <!-- Proveedor -->
   <div class="col-md-6">
  <label asp-for="ProveedorId" class="form-label">
      <i class="bi bi-truck me-1"></i>Proveedor (Opcional)
  </label>
     <select asp-for="ProveedorId" class="form-select" asp-items="ViewBag.ProveedorId">
     <option value="">-- Seleccione un proveedor --</option>
   </select>
  <span asp-validation-for="ProveedorId" class="text-danger small"></span>
          </div>
 </div>

   <hr class="my-4" />

    <div class="d-flex justify-content-end gap-2">
 <a asp-action="Index" class="btn btn-outline-secondary">
<i class="bi bi-x-lg me-1"></i>Cancelar
           </a>
    <button type="submit" class="btn btn-success">
    <i class="bi bi-check-lg me-1"></i>Crear Producto
    </button>
    </div>
 </form>
            </div>
      </div>
        </div>

  <!-- Panel de ayuda -->
 <div class="col-lg-4">
       <div class="card border-0 shadow-sm">
     <div class="card-header bg-light border-0">
   <h6 class="mb-0">
    <i class="bi bi-info-circle me-1"></i>Informacion
   </h6>
    </div>
   <div class="card-body">
      <ul class="list-unstyled mb-0">
     <li class="mb-2">
     <i class="bi bi-check-circle text-success me-2"></i>
   <small>El nombre es obligatorio</small>
      </li>
       <li class="mb-2">
      <i class="bi bi-check-circle text-success me-2"></i>
       <small>Precio debe ser mayor a 0</small>
    </li>
     <li class="mb-2">
    <i class="bi bi-check-circle text-success me-2"></i>
        <small>Stock no puede ser negativo</small>
    </li>
       <li class="mb-2">
            <i class="bi bi-check-circle text-success me-2"></i>
  <small>Categoria es obligatoria</small>
   </li>
   <li>
  <i class="bi bi-info-circle text-info me-2"></i>
    <small>Proveedor es opcional</small>
    </li>
 </ul>
      </div>
</div>
 </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
