@model Proyecto_lab_proweb.ViewModels.DashboardViewModel

@{
	ViewData["Title"] = "Dashboard";
}

<div class="container-fluid position-relative overflow-hidden p-0" style="min-height: 100vh;">
	<div class="position-absolute top-0 start-0 w-100 h-100" style="background-image: url('/img/fime.png'); background-size: cover; background-position: center; background-repeat: no-repeat; filter: blur(8px); transform: scale(1.05);"></div>
	<div class="position-absolute top-0 start-0 w-100 h-100" style="background-color: rgba(0, 0, 0, 0.45);"></div>
	<div class="position-relative px-4 py-4">
	<!-- Encabezado -->
	<div class="d-flex justify-content-between align-items-center mb-4">
		<div>
			<h1 class="h3 mb-0 text-white">
				<i class="bi bi-speedometer2 me-2 text-white"></i>Dashboard
			</h1>
			<p class="text-white mb-0">Bienvenido al panel de administracion</p>
		</div>
		<div>
			<span class="badge bg-primary fs-6">
				<i class="bi bi-calendar3 me-1"></i>@DateTime.Now.ToString("dddd, dd MMMM yyyy")
			</span>
		</div>
	</div>

	<!-- Tarjetas de Estadisticas -->
	<div class="row g-4 mb-4">
		<!-- Total Productos -->
		<div class="col-xl-3 col-md-6">
			<div class="card border-0 shadow-sm h-100">
				<div class="card-body">
					<div class="d-flex justify-content-between align-items-center">
						<div>
							<h6 class="text-muted text-uppercase small mb-1">Total Productos</h6>
							<h2 class="mb-0 fw-bold text-primary">@Model.TotalProductos</h2>
						</div>
						<div class="bg-primary bg-opacity-10 rounded-circle p-3">
							<i class="bi bi-box text-primary fs-4"></i>
						</div>
					</div>
					<a asp-controller="Productos" asp-action="Index" class="stretched-link"></a>
				</div>
				<div class="card-footer bg-transparent border-0 pt-0">
					<small class="text-muted">
						<i class="bi bi-arrow-right me-1"></i>Ver todos los productos
					</small>
				</div>
			</div>
		</div>

		<!-- Total Categorias -->
		<div class="col-xl-3 col-md-6">
			<div class="card border-0 shadow-sm h-100">
				<div class="card-body">
					<div class="d-flex justify-content-between align-items-center">
						<div>
							<h6 class="text-muted text-uppercase small mb-1">Total Categorias</h6>
							<h2 class="mb-0 fw-bold text-success">@Model.TotalCategorias</h2>
						</div>
						<div class="bg-success bg-opacity-10 rounded-circle p-3">
							<i class="bi bi-tags text-success fs-4"></i>
						</div>
					</div>
					<a asp-controller="Categorias" asp-action="Index" class="stretched-link"></a>
				</div>
				<div class="card-footer bg-transparent border-0 pt-0">
					<small class="text-muted">
						<i class="bi bi-arrow-right me-1"></i>Ver todas las categorias
					</small>
				</div>
			</div>
		</div>

		<!-- Total Proveedores -->
		<div class="col-xl-3 col-md-6">
			<div class="card border-0 shadow-sm h-100">
				<div class="card-body">
					<div class="d-flex justify-content-between align-items-center">
						<div>
							<h6 class="text-muted text-uppercase small mb-1">Total Proveedores</h6>
							<h2 class="mb-0 fw-bold text-info">@Model.TotalProveedores</h2>
						</div>
						<div class="bg-info bg-opacity-10 rounded-circle p-3">
							<i class="bi bi-truck text-info fs-4"></i>
						</div>
					</div>
					<a asp-controller="Proveedores" asp-action="Index" class="stretched-link"></a>
				</div>
				<div class="card-footer bg-transparent border-0 pt-0">
					<small class="text-muted">
						<i class="bi bi-arrow-right me-1"></i>Ver todos los proveedores
					</small>
				</div>
			</div>
		</div>

		<!-- Valor Total Inventario -->
		<div class="col-xl-3 col-md-6">
			<div class="card border-0 shadow-sm h-100 bg-gradient" style="background: white;">
				<div class="card-body text-white">
					<div class="d-flex justify-content-between align-items-center">
						<div>
							<h6 class="text-muted text-uppercase small mb-1">Valor Inventario</h6>
							<h2 class="mb-0 fw-bold text-info">@Model.ValorTotalInventario.ToString("C")</h2>
						</div>
						<div class="bg-white bg-opacity-25 rounded-circle p-3">
							<i class="bi bi-currency-dollar text-white fs-4"></i>
						</div>
					</div>
				</div>
				<div class="card-footer bg-transparent border-0 pt-0 text-white-50">
					<small class="text-muted">
						<i class="bi bi-graph-up me-1"></i>Valor total en stock
					</small>
				</div>
			</div>
		</div>
	</div>
</div>
