@model Proyecto_lab_proweb.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid">
    <!-- Encabezado -->
 <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
   <h1 class="h3 mb-0">
  <i class="bi bi-speedometer2 me-2"></i>Dashboard
    </h1>
<p class="text-muted mb-0">Bienvenido al panel de administracion</p>
        </div>
  <div>
   <span class="badge bg-primary fs-6">
   <i class="bi bi-calendar3 me-1"></i>@DateTime.Now.ToString("dddd, dd MMMM yyyy")
      </span>
    </div>
    </div>

    <!-- Tarjetas de Estadisticas -->
 <div class="row g-4 mb-4">
        <!-- Total Productos -->
  <div class="col-xl-3 col-md-6">
     <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
   <div class="d-flex justify-content-between align-items-center">
    <div>
        <h6 class="text-muted text-uppercase small mb-1">Total Productos</h6>
        <h2 class="mb-0 fw-bold text-primary">@Model.TotalProductos</h2>
  </div>
   <div class="bg-primary bg-opacity-10 rounded-circle p-3">
      <i class="bi bi-box text-primary fs-4"></i>
        </div>
    </div>
   <a asp-controller="Productos" asp-action="Index" class="stretched-link"></a>
      </div>
      <div class="card-footer bg-transparent border-0 pt-0">
    <small class="text-muted">
         <i class="bi bi-arrow-right me-1"></i>Ver todos los productos
  </small>
        </div>
   </div>
        </div>

      <!-- Total Categorias -->
     <div class="col-xl-3 col-md-6">
   <div class="card border-0 shadow-sm h-100">
    <div class="card-body">
  <div class="d-flex justify-content-between align-items-center">
<div>
    <h6 class="text-muted text-uppercase small mb-1">Total Categorias</h6>
          <h2 class="mb-0 fw-bold text-success">@Model.TotalCategorias</h2>
         </div>
         <div class="bg-success bg-opacity-10 rounded-circle p-3">
   <i class="bi bi-tags text-success fs-4"></i>
   </div>
  </div>
    <a asp-controller="Categorias" asp-action="Index" class="stretched-link"></a>
   </div>
        <div class="card-footer bg-transparent border-0 pt-0">
      <small class="text-muted">
         <i class="bi bi-arrow-right me-1"></i>Ver todas las categorias
            </small>
   </div>
       </div>
        </div>

     <!-- Total Proveedores -->
        <div class="col-xl-3 col-md-6">
       <div class="card border-0 shadow-sm h-100">
   <div class="card-body">
      <div class="d-flex justify-content-between align-items-center">
     <div>
        <h6 class="text-muted text-uppercase small mb-1">Total Proveedores</h6>
       <h2 class="mb-0 fw-bold text-info">@Model.TotalProveedores</h2>
        </div>
        <div class="bg-info bg-opacity-10 rounded-circle p-3">
      <i class="bi bi-truck text-info fs-4"></i>
   </div>
       </div>
     <a asp-controller="Proveedores" asp-action="Index" class="stretched-link"></a>
   </div>
    <div class="card-footer bg-transparent border-0 pt-0">
  <small class="text-muted">
      <i class="bi bi-arrow-right me-1"></i>Ver todos los proveedores
   </small>
     </div>
 </div>
  </div>

    <!-- Valor Total Inventario -->
        <div class="col-xl-3 col-md-6">
      <div class="card border-0 shadow-sm h-100 bg-gradient" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
      <div class="card-body text-white">
        <div class="d-flex justify-content-between align-items-center">
       <div>
    <h6 class="text-white-50 text-uppercase small mb-1">Valor Inventario</h6>
 <h2 class="mb-0 fw-bold">@Model.ValorTotalInventario.ToString("C")</h2>
   </div>
 <div class="bg-white bg-opacity-25 rounded-circle p-3">
 <i class="bi bi-currency-dollar text-white fs-4"></i>
  </div>
     </div>
 </div>
 <div class="card-footer bg-transparent border-0 pt-0 text-white-50">
 <small>
  <i class="bi bi-graph-up me-1"></i>Valor total en stock
      </small>
        </div>
          </div>
        </div>
    </div>

    <!-- Alertas de Stock -->
  <div class="row g-4 mb-4">
     <div class="col-md-6">
   <div class="card border-0 shadow-sm border-start border-warning border-4">
        <div class="card-body">
     <div class="d-flex align-items-center">
     <div class="bg-warning bg-opacity-10 rounded-circle p-3 me-3">
         <i class="bi bi-exclamation-triangle text-warning fs-4"></i>
  </div>
       <div>
        <h5 class="mb-1">Productos con Bajo Stock</h5>
 <p class="mb-0 text-muted">
  @Model.ProductosBajoStock producto(s) con 10 unidades o menos
   </p>
         </div>
    </div>
</div>
     </div>
        </div>

       <div class="col-md-6">
 <div class="card border-0 shadow-sm border-start border-danger border-4">
  <div class="card-body">
 <div class="d-flex align-items-center">
  <div class="bg-danger bg-opacity-10 rounded-circle p-3 me-3">
    <i class="bi bi-x-circle text-danger fs-4"></i>
      </div>
  <div>
       <h5 class="mb-1">Productos Agotados</h5>
   <p class="mb-0 text-muted">
 @Model.ProductosAgotados producto(s) sin stock disponible
            </p>
  </div>
 </div>
     </div>
     </div>
        </div>
    </div>

    <!-- Tablas de Informacion -->
 <div class="row g-4">
        <!-- Productos Recientes -->
        <div class="col-lg-7">
         <div class="card border-0 shadow-sm h-100">
    <div class="card-header bg-white border-0 py-3">
        <div class="d-flex justify-content-between align-items-center">
 <h5 class="mb-0">
     <i class="bi bi-clock-history me-2"></i>Productos Recientes
    </h5>
     <a asp-controller="Productos" asp-action="Crear" class="btn btn-primary btn-sm">
   <i class="bi bi-plus-lg me-1"></i>Nuevo
    </a>
   </div>
  </div>
     <div class="card-body p-0">
     <div class="table-responsive">
     <table class="table table-hover mb-0">
  <thead class="table-light">
    <tr>
     <th>Producto</th>
         <th>Categoria</th>
        <th class="text-end">Precio</th>
        <th class="text-center">Stock</th>
    </tr>
  </thead>
    <tbody>
       @foreach (var producto in Model.ProductosRecientes)
     {
    <tr>
 <td>
      <a asp-controller="Productos" asp-action="Detalles" asp-route-id="@producto.Id" class="text-decoration-none">
       @producto.Nombre
        </a>
          </td>
    <td>
  <span class="badge bg-secondary">@producto.Categoria</span>
     </td>
        <td class="text-end">@producto.Precio.ToString("C")</td>
       <td class="text-center">
            @if (producto.Stock == 0)
    {
       <span class="badge bg-danger">Agotado</span>
     }
     else if (producto.Stock <= 10)
      {
 <span class="badge bg-warning text-dark">@producto.Stock</span>
      }
       else
         {
   <span class="badge bg-success">@producto.Stock</span>
    }
      </td>
    </tr>
          }
        </tbody>
           </table>
     </div>
   </div>
        </div>
        </div>

   <!-- Categorias con mas Productos -->
        <div class="col-lg-5">
      <div class="card border-0 shadow-sm h-100">
  <div class="card-header bg-white border-0 py-3">
       <div class="d-flex justify-content-between align-items-center">
      <h5 class="mb-0">
   <i class="bi bi-bar-chart me-2"></i>Categorias por Productos
    </h5>
         <a asp-controller="Categorias" asp-action="Crear" class="btn btn-success btn-sm">
  <i class="bi bi-plus-lg me-1"></i>Nueva
        </a>
       </div>
      </div>
    <div class="card-body">
     @if (Model.CategoriasMasProductos.Any())
        {
    @foreach (var categoria in Model.CategoriasMasProductos)
     {
   var porcentaje = Model.TotalProductos > 0 ? (categoria.CantidadProductos * 100.0 / Model.TotalProductos) : 0;
      <div class="mb-3">
     <div class="d-flex justify-content-between align-items-center mb-1">
          <span class="fw-medium">@categoria.Nombre</span>
     <span class="badge bg-primary">@categoria.CantidadProductos productos</span>
       </div>
      <div class="progress" style="height: 8px;">
 <div class="progress-bar" role="progressbar" style="width: @porcentaje%"></div>
         </div>
     <small class="text-muted">Valor: @categoria.ValorTotal.ToString("C")</small>
    </div>
         }
 }
     else
      {
      <div class="text-center text-muted py-4">
  <i class="bi bi-inbox fs-1"></i>
     <p class="mt-2">No hay categorias registradas</p>
     </div>
    }
 </div>
         </div>
        </div>
    </div>

    <!-- Accesos Rapidos -->
    <div class="row mt-4">
  <div class="col-12">
     <div class="card border-0 shadow-sm">
          <div class="card-body">
    <h5 class="mb-3">
        <i class="bi bi-lightning me-2"></i>Accesos Rapidos
    </h5>
    <div class="d-flex flex-wrap gap-2">
      <a asp-controller="Productos" asp-action="Crear" class="btn btn-outline-primary">
        <i class="bi bi-plus-circle me-1"></i>Nuevo Producto
         </a>
     <a asp-controller="Categorias" asp-action="Crear" class="btn btn-outline-success">
      <i class="bi bi-plus-circle me-1"></i>Nueva Categoria
   </a>
     <a asp-controller="Proveedores" asp-action="Crear" class="btn btn-outline-info">
     <i class="bi bi-plus-circle me-1"></i>Nuevo Proveedor
            </a>
        <a asp-controller="Home" asp-action="Catalogo" class="btn btn-outline-secondary">
     <i class="bi bi-eye me-1"></i>Ver Catalogo Publico
   </a>
      </div>
       </div>
 </div>
     </div>
    </div>
</div>
